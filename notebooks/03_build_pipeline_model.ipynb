import pandas as pd

contacts = pd.read_csv("../data_clean/contacts_clean.csv")
deals = pd.read_csv("../data_clean/deals_clean.csv")

# Merge on contact ID
df = deals.merge(
    contacts,
    how="left",
    left_on="contactid",
    right_on="contact_id"
)

# Stage order for modeling
stage_order = [
    "appointment",
    "qualified",
    "presentation",
    "decision_maker",
    "contract",
    "closed_won",
    "closed_lost"
]

df["stage_rank"] = df["dealstage"].apply(lambda x: stage_order.index(x) if x in stage_order else None)

# Pipeline value by stage
pipeline_value = (
    df.groupby("dealstage")["amount"]
      .sum()
      .reset_index()
      .sort_values("dealstage")
)

# Conversion rate
conversion = (
    df.groupby("dealstage")["dealid"]
      .count()
      .reset_index()
)

# Forecast (simple weighted pipeline)
weights = {
    "appointment": 0.05,
    "qualified": 0.15,
    "presentation": 0.30,
    "decision_maker": 0.45,
    "contract": 0.70,
    "closed_won": 1.00,
    "closed_lost": 0.00
}

df["weighted_amount"] = df.apply(lambda row: row["amount"] * weights.get(row["dealstage"], 0), axis=1)

forecast = df["weighted_amount"].sum()

df.to_csv("../data_clean/pipeline_model.csv", index=False)

pipeline_value, conversion, forecast

