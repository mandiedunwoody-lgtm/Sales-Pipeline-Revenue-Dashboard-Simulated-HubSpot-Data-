import pandas as pd
from pathlib import Path

BASE_DIR = Path("..").resolve()
DATA_RAW = BASE_DIR / "data_raw"
DATA_CLEAN = BASE_DIR / "data_clean"

deals_path = DATA_RAW / "deals_raw.csv"

deals = pd.read_csv(deals_path)

deals.head()


# Standardize column names
deals.columns = (
    deals.columns
    .str.strip()
    .str.lower()
    .str.replace(" ", "_")
)

# Example expected columns:
# deal_id, contact_id, deal_name, amount, deal_stage,
# created_date, closed_date, owner_name, pipeline

# Drop duplicates
deals = deals.drop_duplicates()

# Remove rows without deal_id
deals = deals.dropna(subset=["deal_id"])

# Ensure numeric amount
deals["amount"] = pd.to_numeric(deals["amount"], errors="coerce").fillna(0)

# Standardize deal_stage
stage_map = {
    "Appointment Scheduled": "appointment_scheduled",
    "Qualified to Buy": "qualified_to_buy",
    "Presentation Scheduled": "presentation_scheduled",
    "Decision Maker Bought-In": "decision_maker_bought_in",
    "Contract Sent": "contract_sent",
    "Closed Won": "closed_won",
    "Closed Lost": "closed_lost",
}
deals["deal_stage"] = (
    deals["deal_stage"]
    .str.strip()
    .map(lambda x: stage_map.get(x, str(x).lower()))
)

# Parse dates
deals["created_date"] = pd.to_datetime(deals["created_date"], errors="coerce")
deals["closed_date"] = pd.to_datetime(deals["closed_date"], errors="coerce")

deals.info()


clean_deals_path = DATA_CLEAN / "deals_clean.csv"
deals.to_csv(clean_deals_path, index=False)

clean_deals_path
