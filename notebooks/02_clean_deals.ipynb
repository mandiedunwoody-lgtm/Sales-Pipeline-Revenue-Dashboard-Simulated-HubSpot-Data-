import pandas as pd

df = pd.read_csv("../deals.csv")

df.columns = (
    df.columns.str.strip()
              .str.lower()
              .str.replace(" ", "_")
)

# Normalize deal stage
df["dealstage"] = (
    df["dealstage"]
    .str.strip()
    .str.lower()
    .replace({
        "appointment scheduled": "appointment",
        "qualified to buy": "qualified",
        "presentation scheduled": "presentation",
        "decision maker bought-in": "decision_maker",
        "contract sent": "contract",
        "closed won": "closed_won",
        "closed lost": "closed_lost"
    })
)

# Clean amount
df["amount"] = (
    df["amount"]
    .astype(str)
    .str.replace(r"[^0-9.]", "", regex=True)
    .astype(float)
)

# Convert dates
date_cols = ["createdate", "closedate"]
for col in date_cols:
    df[col] = pd.to_datetime(df[col], errors="coerce")

# Remove rows with no deal id
df = df[df["dealid"].notna()]

df.to_csv("../data_clean/deals_clean.csv", index=False)

